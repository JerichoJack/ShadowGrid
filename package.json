{
  "name": "worldview",
  "version": "0.1.0",
  "description": "Browser-based geospatial intelligence platform — live flights, satellites, CCTV, and military-grade shaders over a photorealistic 3D globe.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "proxy": "node server/proxy.mjs",
    "dev:all": "node -e \"const {spawn}=require('child_process');['node server/proxy.mjs','vite'].forEach(cmd=>{const[c,...a]=cmd.split(' ');const p=spawn(c,a,{stdio:'inherit',shell:true});p.on('error',console.error)})\"",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "cesium": "^1.115.0",
    "satellite.js": "^5.0.0"
  },
  "devDependencies": {
    "vite": "^5.2.0",
    "vite-plugin-static-copy": "^3.2.0"
  }
}
