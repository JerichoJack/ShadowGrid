# ─────────────────────────────────────────────────────────────────────────────
# WorldView — Environment Variables
# Copy this file to .env and fill in the keys for your chosen map provider.
# ─────────────────────────────────────────────────────────────────────────────

# ── Map Provider ─────────────────────────────────────────────────────────────
# Choose one:  google | cesium | maptiler
#
#   google    Best visuals (photogrammetric city models). Requires a Google
#             Cloud billing account — but stays within the free $200/mo credit
#             for typical dev usage.
#
#   cesium    100% free, no credit card. World terrain + Bing satellite imagery
#             + OSM 3D building footprints. Slightly less photorealistic than
#             Google but fully featured for all WorldView layers.
#             Sign up: https://ion.cesium.com
#
#   maptiler  100% free tier, no credit card. Quantized-mesh terrain +
#             MapTiler satellite imagery. Good mid-point between Cesium ion
#             and Google.
#             Sign up: https://cloud.maptiler.com
#
VITE_MAP_PROVIDER=cesium


# ── Google Maps Platform ──────────────────────────────────────────────────────
# Required only when VITE_MAP_PROVIDER=google
#
# Steps:
#   1. Go to https://console.cloud.google.com
#   2. Create a project (or select an existing one)
#   3. Enable "Map Tiles API":
#      https://console.cloud.google.com/apis/library/tile.googleapis.com
#   4. Go to Credentials → Create API Key
#   5. (Recommended) Restrict the key to "Map Tiles API" and your domain
#
VITE_GOOGLE_MAPS_API_KEY=


# ── Cesium ion ────────────────────────────────────────────────────────────────
# Required only when VITE_MAP_PROVIDER=cesium
# Also recommended for other providers — suppresses ion console warnings.
#
# Steps:
#   1. Go to https://ion.cesium.com and create a free account
#   2. Navigate to Access Tokens → Create token (default scopes are fine)
#   3. Paste the token below
#
VITE_CESIUM_ION_TOKEN=


# ── MapTiler ──────────────────────────────────────────────────────────────────
# Required only when VITE_MAP_PROVIDER=maptiler
#
# Steps:
#   1. Go to https://cloud.maptiler.com and create a free account
#   2. Navigate to Account → API Keys → Copy your default key
#   3. Free tier includes: terrain tiles + satellite imagery (no credit card)
#
VITE_MAPTILER_API_KEY=


# ── OpenSky Network (optional) ───────────────────────────────────────────────
# Increases flight data rate limits. Anonymous access works but is throttled.
# Sign up free at https://opensky-network.org
#
VITE_OPENSKY_USERNAME=
VITE_OPENSKY_PASSWORD=


# ── ADS-B Exchange (optional) ────────────────────────────────────────────────
# Enables military/untracked flight data.
# API info: https://www.adsbexchange.com/data/
#
VITE_ADSB_EXCHANGE_API_KEY=


# ── Default startup location ──────────────────────────────────────────────────
# The camera will open here on launch. Lon/Lat in decimal degrees, Alt in metres.
#
VITE_DEFAULT_LON=-97.7431
VITE_DEFAULT_LAT=30.2672
VITE_DEFAULT_ALT=150000
